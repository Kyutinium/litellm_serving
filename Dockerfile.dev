ARG LITELLM_VERSION=v1.81.14-stable
FROM ghcr.io/berriai/litellm:${LITELLM_VERSION}

COPY litellm_config_dev.yaml /app/config.yaml
COPY strip_thinking.py /app/strip_thinking.py

ENV LITELLM_WORKER_STARTUP_HOOKS=strip_thinking:apply_patch
ENV PYTHONPATH=/app
ENV THINK_OUTPUT_MODE=none

EXPOSE 4999

ENTRYPOINT ["litellm", "--config", "/app/config.yaml", "--port", "4999", "--host", "0.0.0.0", "--detailed_debug"]
